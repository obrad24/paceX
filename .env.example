# ===========================================
# Neon PostgreSQL
# ===========================================
# 1. Idi na https://console.neon.tech → tvoj projekat → Connect
# 2. Kopiraj connection string
#
# Za lokalni dev + migracije — koristi DIRECT connection (bez -pooler):
# DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"
#
# Za Vercel production — koristi POOLED connection (sa -pooler u hostu):
# DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# ===========================================
# Auth.js
# ===========================================
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# ===========================================
# Strava OAuth (Feature 3+)
# ===========================================
STRAVA_CLIENT_ID=""
STRAVA_CLIENT_SECRET=""

# ===========================================
# Cloudinary (Feature 2+)
# ===========================================
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ===========================================
# Email (verification & password reset)
# ===========================================
EMAIL_FROM="PaceX <noreply@pacex.app>"
RESEND_API_KEY=""
